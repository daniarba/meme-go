# ============================================
# SOLANA WALLET (TRADING WALLET KI PRIVATE KEY)
# ============================================
# Base58 private key (Phantom > Settings > Export Private Key se milegi)
# WARNING: Yeh dedicated trading wallet hona chahiye, jis mein sirf wo paisa ho
# jo tum trade karne ke liye willing ho. Main wallet ki key kabhi yahan na daalo.
SOLANA_PRIVATE_KEY=

# ============================================
# HELIUS (RPC + WebSocket data) - helius.dev
# Free tier available, signup karke API key milegi
# ============================================
HELIUS_API_KEY=

# ============================================
# RUGCHECK (rugcheck.xyz) - public API, key zaroori nahi
# GOPLUS (gopluslabs.io) - free tier, optional key
# ============================================
GOPLUS_API_KEY=

# ============================================
# DISCORD BOT
# 1. discord.com/developers/applications > New Application
# 2. Bot tab > Reset Token > yahan paste karo
# 3. Bot ko apne server mein invite karo (OAuth2 > bot scope > Send Messages, Read Messages)
# 4. Jis channel mein alerts/control chahiye, us channel ID yahan daalo
#    (Discord mein Developer Mode on karke channel pe right-click > Copy Channel ID)
# ============================================
DISCORD_BOT_TOKEN=
DISCORD_CONTROL_CHANNEL_ID=
DISCORD_ALERTS_CHANNEL_ID=
# Optional: Server Settings > right-click server icon > Copy Server ID
# Iske bina slash commands (/start, /menu) propagate hone mein ~1 hour lag sakta hai pehli baar.
# Iske sath instant available ho jate hain.
DISCORD_GUILD_ID=

# ============================================
# GMGN COOPERATION API (optional, baad mein add karenge)
# Apply: https://docs.gmgn.ai (Cooperation-API form fill karo)
# ============================================
GMGN_API_KEY=

# ============================================
# RISK MANAGEMENT DEFAULTS
# ============================================
DRY_RUN=true
STARTING_CAPITAL_SOL=0.5
MAX_POSITION_SIZE_PCT=10
MAX_CONCURRENT_POSITIONS=3
DAILY_LOSS_LIMIT_PCT=20
DEFAULT_STOP_LOSS_PCT=25
DEFAULT_TAKE_PROFIT_PCT=50
SLIPPAGE_BPS=300
PRIORITY_FEE_LAMPORTS=200000

# Copy-trading: jin wallets ko follow karna hai (comma separated addresses)
COPY_TRADE_WALLETS=

# ============================================
# TOKEN DISCOVERY SOURCES
# Konse platforms se naye tokens detect karein
# ============================================
ENABLE_PUMPFUN_WATCHER=true
ENABLE_RAYDIUM_LAUNCHLAB_WATCHER=true
# CPMM ki mint-extraction abhi unreliable nikli hai (same mint multiple deployers
# ke sath detect ho raha tha) - default off rakha hai jab tak fix na ho.
ENABLE_RAYDIUM_CPMM_WATCHER=false
ENABLE_MOONSHOT_WATCHER=true

# Naya token detect hone ke kitne sec baad safety check chalayein.
# RugCheck/GoPlus ko brand-new mint index karne mein time lagta hai -
# turant check karoge to "no data" milega aur har token skip ho jayega.
NEW_TOKEN_EVAL_DELAY_SEC=20

# Agar koi source signal nahi de raha, true karo - raw logs Railway logs mein
# dikhenge taake instruction-name keyword fix kiya ja sake. !debug command se
# pehle check karo ke WS events aa bhi rahe hain ya nahi.
DEBUG_LOG_UNMATCHED=false

# Helius free/starter tier ki rate-limit (RPS) kam hoti hai. 4 sources ek sath
# chalne se 429 (rate limited) easily lag jata hai. Yeh saari Helius RPC calls
# (getTransaction, getSignaturesForAddress, getBalance) ke liye max concurrent
# requests ki limit hai. 429 baar-baar Railway logs mein dikhe to yeh kam karo (2-3),
# ya Helius dashboard se apna plan ka RPS limit check karke isi ke hisab se set karo.
RPC_MAX_CONCURRENT=4


# ============================================
# DEV WALLET TRACKER
# Naye token ke deployer ki history check karta hai - kitne purane scam nikle
# ============================================
DEV_WALLET_HISTORY_LIMIT=40
DEV_WALLET_CACHE_TTL_SEC=3600
# NOTE: 0.85 default hai - Pump.fun pe ~95% tokens naturally "dead" ho jate hain
# (scam ki wajah se zaroori nahi), isliye bohot strict threshold (0.5) almost
# har active deployer ko block kar deta tha. RugCheck ka apna "Creator history"
# check bhi isi signal pe overlap karta hai.
DEV_WALLET_MAX_RUG_RATIO=0.85
DEV_WALLET_MIN_HISTORY_TO_JUDGE=3
DEAD_TOKEN_LIQUIDITY_USD=200
DEAD_TOKEN_MIN_AGE_HOURS=12

# ============================================
# ADVANCED STAIRCASE TRAILING STOP
# Format: profit%:locked_profit%,profit%:locked_profit%,...
# Jaise jaise price upar jaye, stop-loss bhi upar lock hota jata hai, kabhi neeche nahi aata
# ============================================
TRAILING_STAIRCASE=15:0,30:15,60:30,100:60,200:120
TRAILING_PCT_FROM_PEAK=20

